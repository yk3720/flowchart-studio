#!/usr/bin/env sh
set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
CONFIG="$REPO_ROOT/.pre-commit-config.yaml"

cd "$REPO_ROOT" || exit 1
npx lint-staged

STAGED=$(git diff --cached --name-only --diff-filter=ACM || true)
if [ -n "$STAGED" ]; then
  if command -v pre-commit >/dev/null 2>&1; then
    pre-commit run --hook-stage pre-commit --config "$CONFIG" --files $STAGED
  elif python -m pre_commit --version >/dev/null 2>&1; then
    python -m pre_commit run --hook-stage pre-commit --config "$CONFIG" --files $STAGED
  else
    echo "pre-commit not found. Install: pip install -e tools/excel_normalize[dev]" >&2
    exit 1
  fi
fi
