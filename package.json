{
  "name": "flowchart-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test e2e --reporter=line",
    "test:e2e:labels": "playwright test e2e/edge-label-placement.spec.ts --reporter=line",
    "excel:template": "python python/scripts/build_template.py",
    "excel:new-device": "python python/scripts/scaffold_device.py",
    "excel:fixture": "python python/scripts/build_fixture.py",
    "excel:normalize": "python -m excel_normalize.cli python/testdata/fixtures/input-device-z00001.xlsx -o python/testdata/fixtures/import-z00001.json",
    "excel:test001:build": "python python/scripts/build_test001.py",
    "excel:test001:normalize": "python python/scripts/normalize_device.py TEST-001",
    "excel:test001": "npm run excel:test001:build ; npm run excel:test001:normalize",
    "excel:a0001:scratch": "python python/scripts/build_a0001_scratch.py",
    "excel:a0001:build": "python python/scripts/build_a0001_master.py",
    "excel:a0001:normalize": "python python/scripts/normalize_device.py A0001",
    "excel:a0001": "npm run excel:a0001:scratch ; npm run excel:a0001:build",
    "excel:demo-devices": "python python/scripts/build_demo_devices.py",
    "seed:demo-devices": "npx tsx --tsconfig tsconfig.json database/src/seed/import-demo-devices.ts",
    "seed:demo-devices:sql": "npx tsx --tsconfig tsconfig.json database/src/seed/import-demo-devices.ts --write-sql",
    "seed:device": "npx tsx --tsconfig tsconfig.json database/src/seed/import-device.ts",
    "seed:a0001": "npx tsx --tsconfig tsconfig.json database/src/seed/import-device.ts A0001",
    "excel:test": "cd python && python -m pytest",
    "excel:lint": "cd python && python -m ruff check . && python -m ruff format --check .",
    "excel:mypy": "cd python && python -m mypy -p excel_normalize"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,html,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.106.2",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  }
}
