# Supabase（本番 / 開発で別プロジェクトを推奨 · ADR-013）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ダミー装置一括 seed（npm run seed:demo-devices）— Dashboard → Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ローカルで Supabase なしで UI だけ動かすときは 1（本番では設定しない）
# E2E（playwright.config）も AUTH_DISABLED=1 を使用
# PLAYWRIGHT_E2E / *_E2E_STUB は Vercel 本番（VERCEL_ENV=production）では無効（lib/supabase/e2eStub.ts）
AUTH_DISABLED=0
