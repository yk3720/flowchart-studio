# Supabase（本番 / 開発で別プロジェクトを推奨 · ADR-013）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ダミー装置一括 seed（npm run seed:demo-devices）— Dashboard → Settings → API → service_role
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ビルド識別子（画面左ナビ下部）— next.config.ts が build 時に自動注入（手動設定不要）
# NEXT_PUBLIC_APP_VERSION / NEXT_PUBLIC_BUILD_SHA / NEXT_PUBLIC_BUILD_ENV / NEXT_PUBLIC_BUILD_TIME
# Vercel: VERCEL_GIT_COMMIT_SHA · VERCEL_ENV を使用

# ローカルで Supabase なしで UI だけ動かすときは 1（本番では設定しない）
# E2E（playwright.config）も AUTH_DISABLED=1 を使用
# PLAYWRIGHT_E2E / AUTH_E2E_STUB / *_E2E_STUB は Vercel 本番（VERCEL_ENV=production）では無効（lib/supabase/e2eStub.ts）
# AUTH_E2E_STUB=1 + AUTH_DISABLED=0 は Playwright test:e2e:import-auth 専用（本番 auth UI · Supabase 不要）
AUTH_DISABLED=0

# FastAPI 装置 xlsx 正規化（ADR-019 · サーバー専用 · ブラウザに出さない）
# ローカル: npm run excel:api:dev とセットで http://localhost:8000
# 本番: docs/runbooks/FASTAPI_RAILWAY_SETUP.md（2026-06-28 暫定: 本番デプロイ保留 · JSON-only 期間は不要）
# FASTAPI_BASE_URL=http://localhost:8000
# FASTAPI_API_KEY=dev-local-api-key-change-me
